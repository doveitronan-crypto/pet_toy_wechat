/* pages/index/index.wxss */
.today-ribbon {
  background-color: #FFFDF8;
  border: 1rpx solid #F6E6DC;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: center;
}

.ribbon-icon {
  font-size: 32rpx;
}

.ribbon-text {
  font-size: 26rpx;
  color: #8C6A52;
  font-weight: 600;
}

/* Pet Profile Card */
.pet-match-card {
  padding: 24rpx 30rpx;
}

.pet-info-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF1EB;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pet-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.pet-title-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #2E2520;
}

.sparkle {
  font-size: 28rpx;
}

.pet-desc {
  font-size: 24rpx;
  color: #8E8E93;
  margin-top: 4rpx;
}

.switch-container {
  display: flex;
  align-items: center;
}

/* Category horizontal chips */
.category-scroll-container {
  width: 100%;
  white-space: nowrap;
}

.category-scroll {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.category-chip {
  display: inline-block;
  padding: 12rpx 30rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8DDD8;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #6C5D55;
  transition: all 0.2s ease;
  margin-right: 14rpx;
}

.category-chip.active {
  background: #FF7A45;
  color: #FFFFFF;
  border-color: #FF7A45;
}

/* Interactive Stage */
.stage-card {
  min-height: 600rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.box-closed-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 40rpx 0;
}

.stage-backdrop {
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(255,122,69,0.12) 0%, rgba(255,122,69,0) 70%);
  z-index: 1;
}

.box-graphic {
  width: 280rpx;
  height: 280rpx;
  border-radius: 40rpx;
  z-index: 2;
  box-shadow: 0 10rpx 30rpx rgba(139, 92, 26, 0.08);
}

.box-shadow {
  width: 180rpx;
  height: 20rpx;
  background: rgba(46, 37, 32, 0.08);
  border-radius: 50%;
  margin-top: 10rpx;
  filter: blur(2rpx);
}

.start-btn {
  width: 80% !important;
  margin-top: 50rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 122, 69, 0.3);
}

.box-hint {
  font-size: 22rpx;
  color: #8E8E93;
  margin-top: 24rpx;
}

/* Shaking Keyframe Animation */
@keyframes shake {
  0% { transform: translate(0, 0) rotate(0deg); }
  10% { transform: translate(-4rpx, -2rpx) rotate(-3deg); }
  20% { transform: translate(-6rpx, 0rpx) rotate(1deg); }
  30% { transform: translate(0rpx, 4rpx) rotate(3deg); }
  40% { transform: translate(2rpx, -3rpx) rotate(-1deg); }
  50% { transform: translate(-2rpx, 4rpx) rotate(2deg); }
  60% { transform: translate(-6rpx, 2rpx) rotate(-3deg); }
  70% { transform: translate(4rpx, 2rpx) rotate(1deg); }
  80% { transform: translate(-2rpx, -4rpx) rotate(-1deg); }
  90% { transform: translate(4rpx, 4rpx) rotate(3deg); }
  100% { transform: translate(0, 0) rotate(0deg); }
}

.shaking {
  animation: shake 0.6s infinite;
}

/* Opened Stage style */
.box-opened-stage {
  display: flex;
  flex-direction: column;
}

.opened-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D231E;
  margin-bottom: 24rpx;
  text-align: center;
}

.toy-card-main {
  background: #FFFDFB;
  border-radius: 20rpx;
  border: 1rpx solid #F1E5DF;
  padding: 24rpx;
}

.toy-horizontal-layout {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.toy-image-wrapper {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #E8DDD8;
  background-color: #FDF9F6;
  flex-shrink: 0;
}

.toy-image {
  width: 100%;
  height: 100%;
}

.toy-details-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.toy-meta-line {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.toy-title-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #2D231E;
  line-height: 1.3;
}

.toy-scores-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.toy-rating {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.star-icon {
  font-size: 24rpx;
}

.rating-val {
  font-size: 22rpx;
  font-weight: bold;
  color: #E28800;
}

.toy-suitability-badge {
  background: #FFF2EC;
  color: #FF7A45;
  font-size: 18rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 40rpx;
  border: 1rpx solid #FFE0D3;
}

.toy-tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.category-badge-pill {
  font-size: 18rpx;
  background-color: #F1F8FF;
  color: #0066CC;
  border: 1rpx solid #D5E8FC;
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  font-weight: bold;
}

.toy-tag-pill {
  font-size: 18rpx;
  background: #FDFDFD;
  color: #8E8E93;
  border: 1rpx solid #EDE9E6;
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  font-weight: 500;
}

.toy-description-text {
  font-size: 22rpx;
  color: #6C5D55;
  line-height: 1.5;
}

/* Recommendation Bubble */
.recommendation-bubble {
  background: #FFF9F6;
  border: 1rpx solid #FFECE2;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 24rpx;
}

.bubble-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.bubble-icon {
  font-size: 28rpx;
}

.bubble-title {
  font-size: 22rpx;
  font-weight: bold;
  color: #8C6A52;
}

.bubble-content {
  font-size: 22rpx;
  color: #55443B;
  line-height: 1.6;
}

/* Action buttons */
.action-footer {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-footer {
  flex: 1;
  font-size: 24rpx;
  font-weight: bold;
  padding: 16rpx 0;
  border-radius: 14rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-footer.secondary {
  background: #FFF7F4;
  color: #FF7A45;
  border: 1rpx solid #FFDEC1;
}

.btn-footer.wishlist-btn {
  background: #FFFFFF;
  color: #333;
  border: 1rpx solid #E5E5EA;
}

.btn-footer.wishlist-btn.active {
  background: #FFF0F0;
  color: #E24C4C;
  border-color: #FFD1D1;
}

.reset-btn {
  width: 100% !important;
  margin-top: 24rpx;
}
