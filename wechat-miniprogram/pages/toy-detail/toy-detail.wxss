/* pages/toy-detail/toy-detail.wxss */
.pb-footer {
  padding-bottom: 180rpx !important;
}

.nav-back-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  cursor: pointer;
}

.back-arrow {
  font-size: 26rpx;
  color: #FF7A45;
}

.back-text {
  font-size: 24rpx;
  color: #FF7A45;
  font-weight: bold;
}

/* Big cover picture */
.detail-image-card {
  padding: 0 !important;
  height: 400rpx;
  overflow: hidden;
  border-radius: 28rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

/* Main Info Card */
.main-info-card {
  padding: 30rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.toy-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #2D231E;
}

.category-tag-badge {
  font-size: 20rpx;
  background-color: #F1F8FF;
  color: #0066CC;
  border: 1rpx solid #D5E8FC;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  font-weight: bold;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 14rpx;
}

.star-icon {
  font-size: 28rpx;
}

.rating-value {
  font-size: 26rpx;
  font-weight: 800;
  color: #E28800;
}

.rating-sub {
  font-size: 22rpx;
  color: #AEAEB2;
}

.divider {
  height: 2rpx;
  background-color: #FFF2EC;
  margin: 24rpx 0;
}

.description-section {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: bold;
  color: #8C6A52;
}

.description-content {
  font-size: 24rpx;
  color: #55443B;
  line-height: 1.6;
}

/* Guide Card */
.guide-card {
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #2D231E;
  margin-bottom: 20rpx;
  display: block;
}

.guide-steps-list {
  background: #FFFDFB;
  border: 1rpx solid #F1E5DF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.guide-step-text {
  font-size: 24rpx;
  color: #55443B;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* Warning alert card */
.warning-card {
  border-color: #FFDEC1 !important;
  background: #FFF7F2 !important;
  padding: 30rpx;
}

.warning-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.warning-icon {
  font-size: 32rpx;
}

.warning-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #E24C4C;
}

.warning-content {
  font-size: 22rpx;
  color: #8A3838;
  line-height: 1.6;
}

/* Floating Footer Actions */
.footer-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-top: 1rpx solid #F1E5DF;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  z-index: 99;
}

.footer-btn {
  flex: 1;
  font-size: 26rpx !important;
  font-weight: bold !important;
  padding: 20rpx 0 !important;
  border-radius: 20rpx !important;
  border: none !important;
  line-height: 1.5 !important;
}

.footer-btn.wishlist {
  background: #FDF9F7 !important;
  color: #333333 !important;
  border: 1rpx solid #E5E5EA !important;
}

.footer-btn.wishlist.active {
  background: #FFF0F0 !important;
  color: #E24C4C !important;
  border-color: #FFD1D1 !important;
}

.footer-btn.primary {
  background: #FF7A45 !important;
  color: #FFFFFF !important;
}
